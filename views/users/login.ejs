<% layout("/layouts/boilerplate") %>

<div class="row mt-5">

    <!-- TITLE -->
    <h1 class="col-6 offset-3 text-center">
        Login to Wanderlust
    </h1>

    <!-- FORM -->
    <div class="col-6 offset-3 mt-3">

        <form
            action="/login"
            method="POST"
            class="needs-validation"
            novalidate
        >

            <!-- USERNAME -->
            <div class="mb-3">
                <label for="username" class="form-label">
                    Username
                </label>

                <input
                    type="text"
                    name="username"
                    id="username"
                    class="form-control"
                    required
                    autofocus
                >

                <div class="invalid-feedback">
                    Please enter username
                </div>
            </div>

            <!-- PASSWORD -->
            <div class="mb-3">
                <label for="password" class="form-label">
                    Password
                </label>

                <input
                    type="password"
                    name="password"
                    id="password"
                    class="form-control"
                    required
                >

                <div class="invalid-feedback">
                    Please enter password
                </div>
            </div>

            <!-- BUTTON -->
            <button class="btn btn-success w-100">
                Login
            </button>

        </form>

    </div>

</div>